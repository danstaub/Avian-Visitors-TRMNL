<style>
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body, html {
    width: 800px;
    height: 480px;
    overflow: hidden;
    background: #fff;
    font-family: 'Georgia', 'Times New Roman', serif;
  }
  #canvas {
    position: relative;
    width: 800px;
    height: 480px;
    background: #fff;
  }
  #title-bar {
    position: absolute;
    top: 0; left: 0;
    width: 800px;
    padding: 6px 14px 4px;
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    border-bottom: 2px solid #000;
    background: #fff;
    z-index: 10;
  }
  #title-bar .title {
    font-size: 15px;
    font-weight: bold;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }
  #title-bar .subtitle {
    font-size: 9px;
    letter-spacing: 0.06em;
    opacity: 0.55;
  }
  #collage {
    position: absolute;
    top: 30px; left: 0;
    width: 800px;
    height: 450px;
    overflow: hidden;
  }
  .bird-tile {
    position: absolute;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: flex-end;
  }
  .bird-tile img {
    display: block;
    object-fit: contain;
  }
  .bird-label {
    font-size: 7px;
    letter-spacing: 0.04em;
    text-align: center;
    line-height: 1.2;
    max-width: 100%;
    overflow: hidden;
    white-space: nowrap;
    text-overflow: ellipsis;
    color: #000;
    margin-top: 1px;
  }
</style>

<div id="canvas">
  <div id="title-bar">
    <span class="title">Avian Visitors</span>
    <span class="subtitle">MECKLENBURG COUNTY · EBIRD · PAST 7 DAYS</span>
  </div>
  <div id="collage">
    <div id="bird-data" style="display:none">{% for bird in birds %}{{ bird.comName }}|{{ bird.sciName }}|{{ bird.howMany }}{% unless forloop.last %},{% endunless %}{% endfor %}</div>
  </div>
</div>

<script>
document.addEventListener("DOMContentLoaded", function () {
  var raw = document.getElementById("bird-data").textContent.trim();
  if (!raw) return;

  var birds = raw.split(",").map(function(entry) {
    var parts = entry.split("|");
    return {
      comName: parts[0],
      sciName: parts[1],
      count: parseInt(parts[2]) || 1
    };
  }).filter(function(b) { return b.comName; });

  if (birds.length === 0) return;

  var AREA_W = 800, AREA_H = 450;
  var CX = AREA_W / 2, CY = AREA_H / 2;
  var MAX_SZ = 160, MIN_SZ = 72;

  var sizes = birds.map(function(_, i) {
    var t = birds.length === 1 ? 0 : i / (birds.length - 1);
    return Math.round(MAX_SZ - t * (MAX_SZ - MIN_SZ));
  });

  var placed = [];
  function overlaps(nx, ny, nsz) {
    for (var p = 0; p < placed.length; p++) {
      var dx = nx - placed[p].x, dy = ny - placed[p].y;
      if (Math.sqrt(dx*dx + dy*dy) < (nsz + placed[p].sz) / 2 + 6) return true;
    }
    return false;
  }
  function inBounds(x, y, sz) {
    return x-sz/2>=0 && x+sz/2<=AREA_W && y-sz/2>=0 && y+sz/2<=AREA_H;
  }

  var slots = [];
  birds.forEach(function(bird, i) {
    var sz = sizes[i];
    if (i === 0) {
      slots.push({ x: CX, y: CY, sz: sz });
      placed.push({ x: CX, y: CY, sz: sz });
      return;
    }
    var found = false;
    for (var angle = 0; angle < Math.PI * 24 && !found; angle += 0.18) {
      var r = 12 * angle;
      var a = angle + (i * 2.399);
      var tx = CX + r * Math.cos(a);
      var ty = CY + r * Math.sin(a);
      if (inBounds(tx, ty, sz) && !overlaps(tx, ty, sz)) {
        slots.push({ x: tx, y: ty, sz: sz });
        placed.push({ x: tx, y: ty, sz: sz });
        found = true;
      }
    }
    if (!found) slots.push(null);
  });

  var BASE = "https://bird.onethreenine.net/avian/api/cutout.php";
  var collage = document.getElementById("collage");

  birds.forEach(function(bird, i) {
    var slot = slots[i];
    if (!slot) return;
    var sz = slot.sz;

    var tile = document.createElement("div");
    tile.className = "bird-tile";
    tile.style.left   = (slot.x - sz/2) + "px";
    tile.style.top    = (slot.y - sz/2) + "px";
    tile.style.width  = sz + "px";
    tile.style.height = (sz + 10) + "px";

    var img = document.createElement("img");
    var sci = encodeURIComponent(bird.sciName);
    var com = encodeURIComponent(bird.comName);
    var pose = (i % 3 === 2) ? "flight" : "perched";
    img.src    = BASE + "?sci=" + sci + "&com=" + com + "&pose=" + pose;
    img.width  = sz;
    img.height = sz;
    img.alt    = bird.comName;
    img.onerror = function() { tile.style.display = "none"; };

    var label = document.createElement("div");
    label.className = "bird-label";
    label.textContent = bird.comName;
    label.style.maxWidth = sz + "px";

    tile.appendChild(img);
    tile.appendChild(label);
    collage.appendChild(tile);
  });
});
</script>
