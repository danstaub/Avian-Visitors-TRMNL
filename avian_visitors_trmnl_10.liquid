<style>
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body, html {
    width: 800px;
    height: 480px;
    overflow: hidden;
    background: #fff;
    font-family: 'Georgia', 'Times New Roman', serif;
  }
  #canvas {
    position: relative;
    width: 800px;
    height: 480px;
    background: #fff;
  }
  #title-bar {
    position: absolute;
    top: 0; left: 0;
    width: 800px;
    padding: 6px 14px 4px;
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    border-bottom: 2px solid #000;
    background: #fff;
    z-index: 10;
  }
  #title-bar .title {
    font-size: 15px;
    font-weight: bold;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }
  #title-bar .subtitle {
    font-size: 9px;
    letter-spacing: 0.06em;
    opacity: 0.55;
  }
  #collage {
    position: absolute;
    top: 30px; left: 0;
    width: 800px;
    height: 450px;
    overflow: hidden;
  }
  .bird-tile {
    position: absolute;
    display: flex;
    flex-direction: column;
    align-items: center;
  }
  .bird-tile img {
    display: block;
    object-fit: contain;
  }
  .bird-label {
    font-size: 7px;
    letter-spacing: 0.04em;
    text-align: center;
    line-height: 1.2;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    color: #000;
    margin-top: 2px;
  }
</style>

{%- assign BASE = "https://bird.onethreenine.net/avian/api/cutout.php" -%}
{%- assign cx_list    = "400,530,272,265,454,378,487,637,567,352,275,176" | split: "," -%}
{%- assign cy_list    = "225,207,255,134,346,98,91,224,315,350,348,264"   | split: "," -%}
{%- assign sz_list    = "120,114,108,101,95,89,83,77,71,64,58,52"         | split: "," -%}
{%- assign flight_list = "0,0,1,0,1,0,0,1,0,1,0,0"                       | split: "," -%}

<div id="canvas">
  <div id="title-bar">
    <span class="title">Avian Visitors</span>
    <span class="subtitle">MECKLENBURG COUNTY · EBIRD · PAST 7 DAYS</span>
  </div>
  <div id="collage">
    {%- for bird in data limit: 12 -%}
      {%- assign i      = forloop.index0 -%}
      {%- assign sz     = sz_list[i]     | plus: 0 -%}
      {%- assign cx     = cx_list[i]     | plus: 0 -%}
      {%- assign cy     = cy_list[i]     | plus: 0 -%}
      {%- assign flight = flight_list[i] -%}
      {%- assign half   = sz | divided_by: 2 -%}
      {%- assign left   = cx | minus: half -%}
      {%- assign top    = cy | minus: half -%}
      {%- assign tile_h = sz | plus: 14 -%}
      <div class="bird-tile" style="left:{{ left }}px;top:{{ top }}px;width:{{ sz }}px;height:{{ tile_h }}px;">
        {%- if flight == "1" -%}
          <img src="{{ BASE }}?sci={{ bird.sciName | url_encode }}&com={{ bird.comName | url_encode }}&pose=2" width="{{ sz }}" height="{{ sz }}" alt="{{ bird.comName }}">
        {%- else -%}
          <img src="{{ BASE }}?sci={{ bird.sciName | url_encode }}&com={{ bird.comName | url_encode }}" width="{{ sz }}" height="{{ sz }}" alt="{{ bird.comName }}">
        {%- endif -%}
        <div class="bird-label" style="max-width:{{ sz }}px;">{{ bird.comName }}</div>
      </div>
    {%- endfor -%}
  </div>
</div>
