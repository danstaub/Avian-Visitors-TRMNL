<style>
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body, html {
    width: 800px;
    height: 480px;
    overflow: hidden;
    background: #fff;
    font-family: 'Georgia', 'Times New Roman', serif;
  }
  #canvas {
    position: relative;
    width: 800px;
    height: 480px;
    background: #fff;
  }
  #title-bar {
    position: absolute;
    top: 0; left: 0;
    width: 800px;
    padding: 6px 14px 4px;
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    border-bottom: 2px solid #000;
    background: #fff;
    z-index: 10;
  }
  #title-bar .title {
    font-size: 15px;
    font-weight: bold;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }
  #title-bar .subtitle {
    font-size: 9px;
    letter-spacing: 0.06em;
    opacity: 0.55;
  }
  #collage {
    position: absolute;
    top: 30px; left: 0;
    width: 800px;
    height: 450px;
    overflow: hidden;
  }
  .bird-tile {
    position: absolute;
    display: flex;
    flex-direction: column;
    align-items: center;
  }
  .bird-tile img {
    display: block;
    object-fit: contain;
  }
  .bird-label {
    font-size: 7px;
    letter-spacing: 0.04em;
    text-align: center;
    line-height: 1.2;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    color: #000;
    margin-top: 2px;
  }
</style>

{%- comment -%}
  Pre-computed positions (centre x, centre y) for 12 birds.
  Organic spiral spread across 800x450, clear of edges and each other.
  Sizes step down from 120px (most seen) to 52px (least seen).
{%- endcomment -%}

{%- assign cx_list   = "400,555,245,400,570,220,560,230,430,310,510,290"  | split: "," -%}
{%- assign cy_list   = "210,175,175,345,310,315,95,360,95,95,360,355"     | split: "," -%}
{%- assign sz_list   = "120,108,98,88,80,74,68,64,60,57,54,52"            | split: "," -%}
{%- assign pose_list = "1,1,2,1,2,1,1,2,1,2,1,1"                          | split: "," -%}
{%- assign BASE = "https://bird.onethreenine.net/avian/api/cutout.php" -%}

<div id="canvas">
  <div id="title-bar">
    <span class="title">Avian Visitors</span>
    <span class="subtitle">MECKLENBURG COUNTY · EBIRD · PAST 7 DAYS</span>
  </div>
  <div id="collage">
    {%- for bird in birds limit: 12 -%}
      {%- assign i    = forloop.index0 -%}
      {%- assign sz   = sz_list[i]   | plus: 0 -%}
      {%- assign cx   = cx_list[i]   | plus: 0 -%}
      {%- assign cy   = cy_list[i]   | plus: 0 -%}
      {%- assign pose = pose_list[i] -%}
      {%- assign half = sz | divided_by: 2 -%}
      {%- assign left = cx | minus: half -%}
      {%- assign top  = cy | minus: half -%}
      {%- assign tile_h = sz | plus: 14 -%}
      <div class="bird-tile" style="left:{{ left }}px;top:{{ top }}px;width:{{ sz }}px;height:{{ tile_h }}px;">
        <img src="{{ BASE }}?sci={{ bird.sciName | url_encode }}&com={{ bird.comName | url_encode }}&pose={{ pose }}" width="{{ sz }}" height="{{ sz }}" alt="{{ bird.comName }}">
        <div class="bird-label" style="max-width:{{ sz }}px;">{{ bird.comName }}</div>
      </div>
    {%- endfor -%}
  </div>
</div>
