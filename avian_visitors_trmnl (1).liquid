<style>
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body, html {
    width: 800px;
    height: 480px;
    overflow: hidden;
    background: #fff;
    font-family: var(--font-family);
  }
  #canvas {
    position: relative;
    width: 800px;
    height: 480px;
    background: #fff;
  }
  #title-bar {
    position: absolute;
    top: 0; left: 0;
    width: 800px;
    padding: 6px 14px 4px;
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    border-bottom: 2px solid #000;
    background: #fff;
    z-index: 10;
  }
  #title-bar .title {
    font-size: 15px;
    font-weight: bold;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }
  #title-bar .subtitle {
    font-size: 9px;
    letter-spacing: 0.06em;
    opacity: 0.55;
  }
  #collage {
    position: absolute;
    top: 30px; left: 0;
    width: 800px;
    height: 450px;
    overflow: hidden;
  }
  .bird-tile {
    position: absolute;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
  }
  .bird-tile img {
    display: block;
    object-fit: contain;
  }
  .bird-label {
    font-family: var(--font-family);
    font-size: 13px;
    font-weight: bold;
    text-align: center;
    color: #000;
    line-height: 1.2;
    white-space: nowrap;
  }
</style>

{%- assign CDN = "https://cdn.jsdelivr.net/gh/Twarner491/AvianVisitors@avian-visitors/avian/assets/illustrations/" -%}

<div id="canvas">
  <div id="title-bar">
    <span class="title">Avian Visitors</span>
    <span class="subtitle">HOME · EBIRD · PAST 7 DAYS</span>
  </div>
  <div id="collage"></div>
</div>

<div id="bird-data" style="display:none">{%- for bird in data limit: 100 -%}{{ bird.comName }}|{{ bird.sciName }}{% unless forloop.last %},{% endunless %}{%- endfor -%}</div>

<script>
(function () {
  var CDN = "https://cdn.jsdelivr.net/gh/Twarner491/AvianVisitors@avian-visitors/avian/assets/illustrations/";
  var AW = 800, AH = 450, CX = 400, CY = 225;

  // 5 birds, bigger sizes
  var SIZES = [200, 175, 155, 135, 115];
  var LABEL_H = 22; // height reserved below each image for the name
  var MAX_BIRDS = 5;

  var raw = document.getElementById("bird-data").textContent.trim();
  if (!raw) return;

  var allBirds = raw.split(",").map(function(e) {
    var p = e.split("|");
    return { comName: p[0], sciName: p[1], slug: p[1].toLowerCase().replace(/ /g, "-") };
  }).filter(function(b) { return b.comName && b.sciName; });

  var checked = 0;
  var validBirds = [];

  function onAllChecked() {
    if (validBirds.length === 0) return;

    var birds = validBirds.slice(0, MAX_BIRDS);
    var N = birds.length;

    // Spiral placement — treat each tile as image + label block
    var placed = [];

    function overlaps(nx, ny, tw, th) {
      var pad = 8;
      for (var p = 0; p < placed.length; p++) {
        var dx = Math.abs(nx - placed[p].x);
        var dy = Math.abs(ny - placed[p].y);
        if (dx < (tw + placed[p].w) / 2 + pad && dy < (th + placed[p].h) / 2 + pad) return true;
      }
      return false;
    }

    function inBounds(x, y, tw, th) {
      return x - tw/2 >= 0 && x + tw/2 <= AW && y - th/2 >= 0 && y + th/2 <= AH;
    }

    var slots = [];
    birds.forEach(function(bird, i) {
      var w = SIZES[i] || SIZES[SIZES.length - 1];
      var th = w + LABEL_H; // total tile height including label

      if (i === 0) {
        slots.push({x: CX, y: CY, w: w, h: th});
        placed.push({x: CX, y: CY, w: w, h: th});
        return;
      }

      for (var step = 0; step < 2000; step++) {
        var angle = step * 0.2;
        var r = 5 * angle;
        var tx = CX + r * 1.6 * Math.cos(angle + i * 2.399);
        var ty = CY + r * Math.sin(angle + i * 2.399);
        if (!inBounds(tx, ty, w, th)) continue;
        if (!overlaps(tx, ty, w, th)) {
          slots.push({x: tx, y: ty, w: w, h: th});
          placed.push({x: tx, y: ty, w: w, h: th});
          return;
        }
      }
      slots.push(null);
    });

    var collage = document.getElementById("collage");
    birds.forEach(function(bird, i) {
      var slot = slots[i];
      if (!slot) return;
      var w = slot.w;
      var th = slot.h;

      var tile = document.createElement("div");
      tile.className = "bird-tile";
      tile.style.cssText = "left:"+(slot.x-w/2)+"px;top:"+(slot.y-th/2)+"px;width:"+w+"px;height:"+th+"px;";

      var img = document.createElement("img");
      img.src = CDN + bird.slug + ".png";
      img.width = w;
      img.height = w;
      img.alt = bird.comName;

      var lbl = document.createElement("div");
      lbl.className = "bird-label";
      lbl.style.maxWidth = w + "px";
      lbl.textContent = bird.comName;

      tile.appendChild(img);
      tile.appendChild(lbl);
      collage.appendChild(tile);
    });
  }

  allBirds.forEach(function(bird, i) {
    var img = new Image();
    img.onload = function() {
      validBirds.push({ comName: bird.comName, sciName: bird.sciName, slug: bird.slug, order: i });
      checked++;
      if (checked === allBirds.length) {
        validBirds.sort(function(a,b){ return a.order - b.order; });
        onAllChecked();
      }
    };
    img.onerror = function() {
      checked++;
      if (checked === allBirds.length) {
        validBirds.sort(function(a,b){ return a.order - b.order; });
        onAllChecked();
      }
    };
    img.src = CDN + bird.slug + ".png";
  });
})();
</script>
