<style>
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body, html {
    width: 800px;
    height: 480px;
    overflow: hidden;
    background: #fff;
    font-family: 'Georgia', 'Times New Roman', serif;
  }
  #canvas {
    position: relative;
    width: 800px;
    height: 480px;
    background: #fff;
  }
  #title-bar {
    position: absolute;
    top: 0; left: 0;
    width: 800px;
    padding: 6px 14px 4px;
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    border-bottom: 2px solid #000;
    background: #fff;
    z-index: 10;
  }
  #title-bar .title {
    font-size: 15px;
    font-weight: bold;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }
  #title-bar .subtitle {
    font-size: 9px;
    letter-spacing: 0.06em;
    opacity: 0.55;
  }
  #collage {
    position: absolute;
    top: 30px; left: 0;
    width: 800px;
    height: 450px;
    overflow: hidden;
  }
  .bird-tile {
    position: absolute;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: flex-end;
  }
  .bird-tile img {
    display: block;
    object-fit: contain;
  }
  .bird-label {
    font-size: 7px;
    letter-spacing: 0.04em;
    text-align: center;
    line-height: 1.2;
    max-width: 100%;
    overflow: hidden;
    white-space: nowrap;
    text-overflow: ellipsis;
    color: #000;
    margin-top: 1px;
  }
</style>

<div id="canvas">
  <div id="title-bar">
    <span class="title">Avian Visitors</span>
    <span class="subtitle">MECKLENBURG COUNTY · EBIRD · PAST 7 DAYS</span>
  </div>
  <div id="collage">
    <div id="bird-data" style="display:none">{% for bird in birds %}{{ bird.comName }}|{{ bird.sciName }}|{{ bird.howMany }}{% unless forloop.last %},{% endunless %}{% endfor %}</div>
  </div>
</div>

<script>
document.addEventListener("DOMContentLoaded", function () {
  var raw = document.getElementById("bird-data").textContent.trim();
  if (!raw) return;

  var birds = raw.split(",").map(function(entry) {
    var parts = entry.split("|");
    return {
      comName: parts[0] || "",
      sciName: parts[1] || "",
      count: Math.max(1, parseInt(parts[2]) || 1)
    };
  }).filter(function(b) { return b.comName && b.sciName; });

  if (birds.length === 0) return;

  var AW = 800, AH = 450;
  var CX = AW / 2, CY = AH / 2;
  var N = birds.length;

  var budgetFrac = 0.28 + (Math.max(0, 12 - N) / 12) * 0.18;
  var B = AW * AH * budgetFrac;

  var scores = birds.map(function(b) { return Math.pow(b.count, 0.65); });
  var scoreSum = scores.reduce(function(a, b) { return a + b; }, 0);
  var A_MIN = 55 * 55;

  var baseWidths = scores.map(function(s) {
    var area = Math.max(A_MIN, (B / scoreSum) * s);
    return Math.round(Math.sqrt(area));
  });

  function overlaps(nx, ny, nw, placed) {
    var pad = 6;
    for (var p = 0; p < placed.length; p++) {
      var dx = Math.abs(nx - placed[p].x);
      var dy = Math.abs(ny - placed[p].y);
      var minX = (nw + placed[p].w) / 2 + pad;
      var minY = (nw + placed[p].w) / 2 + pad;
      if (dx < minX && dy < minY) return true;
    }
    return false;
  }

  function inBounds(x, y, w) {
    var half = w / 2;
    return x - half >= 2 && x + half <= AW - 2 && y - half >= 2 && y + half <= AH - 2;
  }

  function tryLayout(scale) {
    var ws = baseWidths.map(function(w) { return Math.max(40, Math.round(w * scale)); });
    var placed = [];
    var slots = [];

    for (var i = 0; i < birds.length; i++) {
      var w = ws[i];

      if (i === 0) {
        slots.push({ x: CX, y: CY, w: w });
        placed.push({ x: CX, y: CY, w: w });
        continue;
      }

      var found = false;
      // Walk the Archimedean spiral until we find a valid non-overlapping spot
      for (var step = 0; step < 800; step++) {
        var angle = step * 0.25;
        var r = 5 * angle;
        var a = angle + i * 2.399;
        var tx = CX + r * Math.cos(a);
        var ty = CY + r * Math.sin(a);
        if (!inBounds(tx, ty, w)) continue;
        if (!overlaps(tx, ty, w, placed)) {
          slots.push({ x: tx, y: ty, w: w });
          placed.push({ x: tx, y: ty, w: w });
          found = true;
          break;
        }
      }

      if (!found) return null;
    }

    return slots;
  }

  var slots = null;
  var scale = 1.0;
  for (var attempt = 0; attempt < 10; attempt++) {
    slots = tryLayout(scale);
    if (slots) break;
    scale *= 0.93;
  }
  if (!slots) return;

  var BASE = "https://bird.onethreenine.net/avian/api/cutout.php";
  var collage = document.getElementById("collage");

  birds.forEach(function(bird, i) {
    var slot = slots[i];
    if (!slot) return;
    var w = slot.w;

    var tile = document.createElement("div");
    tile.className = "bird-tile";
    tile.style.left   = (slot.x - w/2) + "px";
    tile.style.top    = (slot.y - w/2) + "px";
    tile.style.width  = w + "px";
    tile.style.height = (w + 10) + "px";

    var img = document.createElement("img");
    var sci = encodeURIComponent(bird.sciName);
    var com = encodeURIComponent(bird.comName);
    var pose = (i % 3 === 2) ? "2" : "1";
    img.src    = BASE + "?sci=" + sci + "&com=" + com + "&pose=" + pose;
    img.width  = w;
    img.height = w;
    img.alt    = bird.comName;
    img.onerror = function() { tile.style.display = "none"; };

    var label = document.createElement("div");
    label.className = "bird-label";
    label.textContent = bird.comName;
    label.style.maxWidth = w + "px";

    tile.appendChild(img);
    tile.appendChild(label);
    collage.appendChild(tile);
  });
});
</script>
